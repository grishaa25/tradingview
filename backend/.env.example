# --- Supabase ---------------------------------------------------------
# Dashboard → Settings → Database → Connection string (URI).
# Use the Session pooler (port 5432) or direct connection for this
# long-running backend; swap the scheme to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server-only, bypasses RLS — never expose
SUPABASE_JWT_SECRET=<jwt-secret>               # verifies user tokens on API requests

# --- Brokers (Phase 1) -------------------------------------------------
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# --- Alerts ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI (LiteLLM reads provider keys from env) --------------------------
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
AI_MONTHLY_BUDGET_USD=20

# --- Misc ---------------------------------------------------------------
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
